    subgraph Support["Support Modules"]
        NETWORK["SwiftIntelligenceNetwork"]
        CACHE["SwiftIntelligenceCache"]
        METRICS["SwiftIntelligenceMetrics"]
        BENCH["SwiftIntelligenceBenchmarks"]
    end

    subgraph Apple["Apple Frameworks"]
        VFW["Vision"]
        NLFW["NaturalLanguage"]
        SFW["Speech / AVFoundation"]
        CMFW["Core ML"]
        CKFW["CryptoKit"]
    end

    APP --> CORE
    DEMO --> CORE

    CORE --> CFG
    CORE --> LOG

    CORE --> ML
    CORE --> NLP
    CORE --> VISION
    CORE --> SPEECH
