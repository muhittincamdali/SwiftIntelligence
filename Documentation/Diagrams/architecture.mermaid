graph TB
    subgraph Apps["Application Layer"]
        APP["iOS / macOS / visionOS Apps"]
        DEMO["Demo Apps and Examples"]
    end

    subgraph Core["Core Layer"]
        CORE["SwiftIntelligenceCore"]
        CFG["IntelligenceConfiguration"]
        LOG["Logging / Metrics / Error Handling"]
    end

    subgraph Capability["Capability Modules"]
        ML["SwiftIntelligenceML"]
        NLP["NLPEngine"]
        VISION["VisionEngine"]
        SPEECH["SpeechEngine"]
        PRIVACY["SwiftIntelligencePrivacy"]
        TOKEN["PrivacyTokenizer"]
        REASON["SwiftIntelligenceReasoning"]
