graph TB
    subgraph Source["Source of Truth"]
        GIT["GitHub Repository"]
        DOCS["Repository Documentation"]
        PKG["Package.swift"]
    end

    subgraph Validation["Validation"]
        CI["GitHub Actions CI"]
        BUILD["swift build"]
        TEST["swift test"]
        BENCH["Benchmark Artifacts"]
    end

    subgraph Distribution["Distribution"]
        SPI["Swift Package Index"]
        REL["GitHub Releases"]
        SPM["Swift Package Manager Consumers"]
    end

    subgraph Targets["Apple Platforms"]
        IOS["iOS"]
        MAC["macOS"]
        TV["tvOS"]
        WATCH["watchOS"]
        VOS["visionOS"]
    end

    GIT --> DOCS
    GIT --> PKG
    GIT --> CI
    CI --> BUILD
    CI --> TEST
    CI --> BENCH
    PKG --> SPI
    GIT --> REL
    SPI --> SPM
    SPM --> IOS
    SPM --> MAC
    SPM --> TV
    SPM --> WATCH
    SPM --> VOS
