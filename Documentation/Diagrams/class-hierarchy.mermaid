classDiagram
    class SwiftIntelligenceCore {
        +shared
        +configure(with:)
        +resetConfiguration()
        +memoryUsage()
        +cpuUsage()
        +cleanup()
    }

    class SwiftIntelligenceML {
        <<actor>>
        +train(modelID:with:)
        +predict(modelID:input:)
        +evaluate(modelID:testData:)
        +clearCache()
        +shutdown()
    }

    class NLPEngine {
        <<MainActor>>
        +shared
        +analyze(text:options:)
        +analyzeSentiment(text:language:)
        +extractNamedEntities(text:language:)
        +summarizeText(text:maxSentences:)
    }

    class VisionEngine {
        <<MainActor>>
        +shared
        +initialize()
        +classifyImage(_:options:)
        +detectObjects(in:options:)
        +recognizeText(in:options:)
        +segmentImage(_:options:)
        +shutdown()
    }

    class SpeechEngine {
        <<MainActor>>
        +shared
        +startSpeechRecognition(language:options:)
        +recognizeSpeech(from:language:options:)
        +synthesizeSpeech(from:voice:options:)
        +availableVoices(for:)
    }

    class SwiftIntelligencePrivacy {
        <<actor>>
        +encryptData(_:algorithm:level:)
        +storeSecureData(_:key:options:)
        +getAuditLog(filter:)
        +shutdown()
    }

    class PrivacyTokenizer {
        +tokenize(_:context:)
        +detokenize(_:)
        +formatPreservingTokenize(_:context:)
    }

    SwiftIntelligenceCore --> NLPEngine
    SwiftIntelligenceCore --> VisionEngine
    SwiftIntelligenceCore --> SpeechEngine
    SwiftIntelligenceCore --> SwiftIntelligenceML
    SwiftIntelligenceCore --> SwiftIntelligencePrivacy
    SwiftIntelligencePrivacy --> PrivacyTokenizer
